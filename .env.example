# Copy to .env.local and fill in values. Never commit .env.local.

# Database (required)
DATABASE_URL="postgresql://..."

# Stripe (required for payments)
STRIPE_SECRET_KEY="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."

# Admin (required)
ADMIN_EMAIL="your@email.com"
ADMIN_SESSION_SECRET="random-32-char-secret"

# Resend (required for emails)
RESEND_API_KEY="re_..."

# Optional - public (safe to expose)
NEXT_PUBLIC_SITE_URL="https://yoursite.com"
NEXT_PUBLIC_PHONE_NUMBER="+1 (647) 459-4188"
NEXT_PUBLIC_WHATSAPP_NUMBER="16474594188"
NEXT_PUBLIC_SCHEDULER_MODE="custom"
NEXT_PUBLIC_PAYMENT_HOLD_MINUTES="15"

# Optional - Google Calendar
GOOGLE_CLIENT_EMAIL="..."
GOOGLE_PRIVATE_KEY="..."
GOOGLE_CALENDAR_ID="..."
GOOGLE_SITE_VERIFICATION="..."

# Optional - Instagram
IG_USER_ID=""
IG_USER_TOKEN=""
FB_APP_ID=""
FB_APP_SECRET=""

# Optional - Cal.com embed
NEXT_PUBLIC_CAL_VENDOR="calcom"
NEXT_PUBLIC_CAL_EVENT_TYPE_SLUG=""

# Optional - business config
BUSINESS_TIMEZONE="America/Toronto"
PAYMENT_HOLD_MINUTES="15"
SLOT_INTERVAL_MINUTES="60"
TRAVEL_BUFFER_MINUTES="60"
BOOKING_MIN_NOTICE_HOURS="24"

# Optional - tracking
TRACKING_API_SECRET=""
CAL_WEBHOOK_SECRET=""
