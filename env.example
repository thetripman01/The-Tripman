# Example environment variables
# Copy to `.env.local` for local development and fill in your real values.
# Never commit real secrets.

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://username:password@hostname:port/database?sslmode=require"

# ===========================================
# STRIPE
# ===========================================
# Use test keys locally unless you specifically need live mode.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ===========================================
# EMAIL (Resend)
# ===========================================
RESEND_API_KEY="re_..."

# ===========================================
# SITE / APP
# ===========================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SCHEDULER_MODE="custom" # embed | custom
SCHEDULER_MODE="custom" # embed | custom (server-side; keep in sync)

# ===========================================
# ADMIN (cookie session)
# ===========================================
# Used only by seed scripts to create/update the admin user:
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
#
# Required at runtime (signs/verifies the admin session cookie):
ADMIN_SESSION_SECRET="generate-a-long-random-string"

# ===========================================
# BUSINESS RULES
# ===========================================
BUSINESS_TIMEZONE="America/Toronto"
BUFFER_MINUTES=15
BOOKING_MIN_NOTICE_HOURS=24
CANCEL_POLICY_HOURS=12

# ===========================================
# OPTIONAL: GOOGLE CALENDAR (custom scheduler integration)
# ===========================================
GOOGLE_CALENDAR_ID=""
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""

# ===========================================
# OPTIONAL: ANALYTICS
# ===========================================
NEXT_PUBLIC_GA4_ID=""

