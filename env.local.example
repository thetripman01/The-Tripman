# Copy this file to `.env.local` and replace values.
# Do NOT commit real secrets.

# ===========================================
# DATABASE (Neon / Postgres)
# ===========================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ===========================================
# EMAIL (Resend)
# ===========================================
RESEND_API_KEY="re_..."

# ===========================================
# STRIPE (Payments)
# ===========================================
# Use test keys locally. Switch to live keys in Vercel Production.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From Stripe Webhook endpoint for `/api/payment/webhook`
STRIPE_WEBHOOK_SECRET="whsec_..."

# ===========================================
# SITE CONFIGURATION
# ===========================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Scheduler mode
# - embed: cal.com / calendly embed
# - custom: in-app calendar + booking
NEXT_PUBLIC_SCHEDULER_MODE="custom"
SCHEDULER_MODE="custom"

# ===========================================
# ADMIN (seed-time + runtime session signing)
# ===========================================
# Seed-time only (creates/updates AdminUser in DB)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Runtime required (cookie-based admin session signing)
# Generate a long random string and keep it stable.
ADMIN_SESSION_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"

# ===========================================
# BUSINESS CONFIGURATION
# ===========================================
BUSINESS_TIMEZONE="America/Toronto"
BUFFER_MINUTES=15
BOOKING_MIN_NOTICE_HOURS=24
CANCEL_POLICY_HOURS=12

# ===========================================
# CONTACT (optional, used in UI)
# ===========================================
# WhatsApp format: country code + number, no plus or spaces (e.g. 14161234567)
NEXT_PUBLIC_WHATSAPP_NUMBER="16474594188"
# Phone can include + and spaces; used for tel: links
NEXT_PUBLIC_PHONE_NUMBER="+1 (647) 459-4188"

# ===========================================
# TRACKING (recommended if you will use /api/tracking/update-*)
# ===========================================
TRACKING_API_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"

# ===========================================
# GOOGLE CALENDAR (only if SCHEDULER_MODE=custom and you want calendar blocking)
# ===========================================
GOOGLE_CALENDAR_ID=""
GOOGLE_CLIENT_EMAIL=""
# Keep literal \n newlines (do not paste raw multi-line key)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ===========================================
# ANALYTICS (optional)
# ===========================================
NEXT_PUBLIC_GA4_ID=""
GOOGLE_SITE_VERIFICATION=""

# ===========================================
# INSTAGRAM (optional: removes “Instagram credentials not configured”)
# ===========================================
IG_USER_ID=""
IG_USER_TOKEN=""
FB_APP_ID=""
FB_APP_SECRET=""

# ===========================================
# EMBED MODE (only if NEXT_PUBLIC_SCHEDULER_MODE=embed)
# ===========================================
CAL_VENDOR="calcom" # calcom | calendly
CAL_EVENT_TYPE_SLUG="your-username/your-event"
CAL_WEBHOOK_SECRET="change-me"

