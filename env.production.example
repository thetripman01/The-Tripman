# TripMan Production Environment Variables
# Copy this file to .env.local and fill in your actual values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Get this from Neon (https://neon.tech) or your PostgreSQL provider
DATABASE_URL="postgresql://username:password@hostname:port/database"

# ===========================================
# STRIPE PAYMENT CONFIGURATION
# ===========================================
# Get these from your Stripe dashboard (https://dashboard.stripe.com)
STRIPE_SECRET_KEY="sk_live_..." # Live key for production
STRIPE_PUBLISHABLE_KEY="pk_live_..." # Live key for production
STRIPE_WEBHOOK_SECRET="whsec_..." # Webhook endpoint secret

# ===========================================
# EMAIL CONFIGURATION (Resend)
# ===========================================
# Get this from Resend (https://resend.com)
RESEND_API_KEY="re_..."

# ===========================================
# SITE CONFIGURATION
# ===========================================
NEXT_PUBLIC_SITE_URL="https://tripman.com" # Your production domain
NEXT_PUBLIC_SCHEDULER_MODE="custom" # embed | custom
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..." # Same as above, for frontend

# ===========================================
# ADMIN AUTHENTICATION
# ===========================================
ADMIN_EMAIL="admin@tripman.com"
ADMIN_PASSWORD="your-secure-admin-password"

# ===========================================
# BUSINESS CONFIGURATION
# ===========================================
BUSINESS_TIMEZONE="America/Toronto"
BUFFER_MINUTES=15
BOOKING_MIN_NOTICE_HOURS=24
CANCEL_POLICY_HOURS=12

# ===========================================
# GOOGLE CALENDAR INTEGRATION
# ===========================================
# Get these from Google Cloud Console
GOOGLE_CALENDAR_ID="your-calendar@group.calendar.google.com"
GOOGLE_CLIENT_EMAIL="service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# ===========================================
# ANALYTICS
# ===========================================
NEXT_PUBLIC_GA4_ID="G-XXXXXXXXXX" # Google Analytics 4 ID

# ===========================================
# EMBED MODE CONFIGURATION (if using Cal.com/Calendly)
# ===========================================
CAL_VENDOR="calcom" # calcom | calendly
CAL_EVENT_TYPE_SLUG="your-calendar/event-type"
CAL_WEBHOOK_SECRET="your-webhook-secret"

# ===========================================
# SEO CONFIGURATION
# ===========================================
GOOGLE_SITE_VERIFICATION="your-verification-code"

# ===========================================
# REAL-TIME TRACKING CONFIGURATION
# ===========================================
# Optional: Configure for enhanced tracking features
TRACKING_UPDATE_INTERVAL=30000 # Update interval in milliseconds (30 seconds)
TRACKING_ACCURACY_THRESHOLD=100 # Minimum accuracy in meters

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# Generate a secure random string for session encryption
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="https://tripman.com"

# ===========================================
# MONITORING & LOGGING
# ===========================================
# Optional: Add monitoring services
# SENTRY_DSN="your-sentry-dsn"
# LOG_LEVEL="info" # debug | info | warn | error

# ===========================================
# DEVELOPMENT vs PRODUCTION
# ===========================================
NODE_ENV="production"
NEXT_PUBLIC_APP_ENV="production"
