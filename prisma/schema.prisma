// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EventType {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  durationMin Int
  priceCents  Int?
  isActive    Boolean  @default(true)
  bookings    Booking[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id              String        @id @default(cuid())
  eventTypeId     String
  eventType       EventType     @relation(fields: [eventTypeId], references: [id])
  fullName        String
  email           String
  phone           String?
  notes           String?
  timezone        String
  startsAt        DateTime
  endsAt          DateTime
  // Legacy free-text pickup field. Kept nullable for backward compatibility
  // with bookings created before structured location fields existed.
  // New bookings additionally populate pickupCountry/pickupCity/pickupAddress
  // and also write a human-readable combined string here for display fallbacks.
  pickup          String?
  // Structured pickup location (introduced 2026-06). All three are required
  // for new bookings; nullable in schema only to preserve legacy rows.
  pickupCountry   String?
  pickupCity      String?
  pickupAddress   String?
  peopleCount     Int?
  status          BookingStatus @default(PENDING)
  googleEventId   String?       // For custom mode: store Google Calendar event ID
  paymentIntentId String?        // Stripe payment intent ID
  paymentStatus   PaymentStatus @default(PENDING)
  amountPaid      Int?          // Total amount Stripe captured, in cents (subtotal + tax)
  // Tax breakdown captured at booking-creation time so historical receipts
  // stay correct even if rates change later. All nullable for back-compat
  // with bookings made before this column existed.
  subtotalCents   Int?          // Pre-tax amount in cents
  taxCents        Int?          // Tax amount in cents (= subtotal * taxRate, rounded)
  taxRate         Float?        // Rate applied (e.g. 0.13 for HST 13%)
  currency        String?       // Lowercase ISO 4217 ("cad" / "usd")
  ride            Ride?         // Real-time tracking
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// A bookable pickup location (country + city) that customers can choose
// when making a booking. Admin manages this list.
//
// Availability semantics:
//   - isActive == false           => never bookable, hidden from customers
//   - availableFrom == null AND
//     availableUntil == null      => always bookable (e.g. permanent GTA cities)
//   - availableFrom set / both    => bookable only when the booking's start
//     date falls within [availableFrom, availableUntil] (inclusive).
//
// This lets the admin model both "permanent" service cities and short-lived
// tour windows (e.g. Ottawa only Jul 12-14) with a single schema.
model ServiceLocation {
  id             String    @id @default(cuid())
  country        String
  city           String
  // Master switch. Admin can flip off without losing date range / settings.
  isActive       Boolean   @default(true)
  // Optional date window. Null on both => always available. Inclusive bounds.
  availableFrom  DateTime?
  availableUntil DateTime?
  // If true, this row is the default city pre-selected for its country in
  // the public booking form. At most one default per country (enforced in
  // application code, not DB).
  isDefault      Boolean   @default(false)
  // If true, when this row's date window covers the booking date,
  // ONLY exclusive rows are bookable that day — all other (non-exclusive)
  // cities are hidden. Used for tours: marking "Montreal" exclusive with
  // window Jul 18–21 hides every GTA city on those dates without manually
  // disabling them. Multiple exclusive rows can coexist (e.g. NY + NJ).
  exclusive      Boolean   @default(false)
  // Internal admin note (e.g. "Tour window – Bekir announced 2026-05-31").
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([country, city])
  @@index([isActive, country])
}

model AvailabilityBlock {
  id        String   @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AvailabilityRule {
  id         String   @id @default(cuid())
  timezone   String   @default("America/Toronto")
  daysOfWeek Int[]
  startTime  String   // "HH:MM"
  endTime    String   // "HH:MM" (if earlier than startTime => overnight)
  isAvailable Boolean @default(true)
  startDate  DateTime?
  endDate    DateTime?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ride {
  id          String      @id @default(cuid())
  bookingId   String      @unique
  booking     Booking     @relation(fields: [bookingId], references: [id])
  driverId    String?
  driverName  String?
  driverPhone String?
  vehicleInfo String?
  status      RideStatus  @default(ASSIGNED)
  startTime   DateTime?
  endTime     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  locations   Location[]
}

model Location {
  id        String   @id @default(cuid())
  rideId    String
  ride      Ride     @relation(fields: [rideId], references: [id])
  latitude  Float
  longitude Float
  address   String?
  timestamp DateTime @default(now())
  accuracy  Float?
  speed     Float?
  heading   Float?
}

enum RideStatus {
  ASSIGNED
  DRIVER_EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
